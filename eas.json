{
  "cli": {
    "version": ">= 18.8.1",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "environment": "development"
    },
    "preview": {
      "distribution": "internal",
      "environment": "preview"
    },
    "production": {
      "autoIncrement": true,
      "environment": "production",
      "node": "20.11.0",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "GRADLE_OPTS": "-Dorg.gradle.jvmargs=-Xmx4096m"
      }
    }
  },
  "submit": {
    "production": {}
  }
}