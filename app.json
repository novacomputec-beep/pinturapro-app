{
  "expo": {
    "name": "ArrumaPro",
    "slug": "pinturapro",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.pinturapro.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Usamos sua localização para mostrar obras próximas a você.",
        "NSCameraUsageDescription": "Precisamos da câmera para tirar fotos e gravar vídeos.",
        "NSMicrophoneUsageDescription": "Precisamos do microfone para gravar vídeos.",
        "NSPhotoLibraryUsageDescription": "Precisamos acessar sua galeria para adicionar fotos e vídeos."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#E8833A"
      },
      "package": "com.pinturapro.app",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO"
      ]
    },
    "plugins": [
      "expo-location",
      "expo-secure-store",
      "expo-notifications",
      [
        "expo-image-picker",
        {
          "photosPermission": "Precisamos acessar sua galeria para adicionar fotos e vídeos.",
          "cameraPermission": "Precisamos da câmera para tirar fotos e gravar vídeos.",
          "microphonePermission": "Precisamos do microfone para gravar vídeos."
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "kotlinVersion": "1.9.24",
            "compileSdkVersion": 34,
            "targetSdkVersion": 34,
            "buildToolsVersion": "34.0.0"
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "bf289259-dbe3-429f-9032-dcaca21f0a8a"
      }
    }
  }
}